{
  "name": "agenticpay-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "MCP-native pay-per-tool-call micropayments for AI agents (Solana + USDC + x402)",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist .turbo node_modules && rm -rf node_modules",
    "heroku-postbuild": "pnpm -r build",
    "start": "node packages/facilitator/dist/index.js"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^26.0.1",
    "tsx": "^4.23.0"
  },
  "pnpm": {
    "overrides": {
      "fast-uri@<3.1.2": ">=3.1.2",
      "ws@>=8.0.0 <8.21.0": "^8.21.0",
      "ws@>=7.0.0 <7.5.11": "^7.5.11",
      "hono@<4.12.25": "^4.12.25",
      "ip-address@<10.1.1": "^10.1.1",
      "qs@>=6.11.1 <6.15.2": "^6.15.2",
      "brace-expansion@>=5.0.0 <5.0.6": "^5.0.6"
    }
  }
}
