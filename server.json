{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "io.github.krystiangw/agenticpay",
  "description": "x402 USDC paywall server for MCP tools on Solana — each tool declares a price.",
  "version": "0.0.1",
  "repository": {
    "url": "https://github.com/krystiangw/agenticpay",
    "source": "github"
  },
  "websiteUrl": "https://krystiangw.github.io/agenticpay/",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@agenticpay/mcp-server",
      "version": "0.0.1",
      "transport": {
        "type": "streamable-http"
      },
      "environmentVariables": [
        {
          "name": "PAY_TO",
          "description": "Solana pubkey that receives payments",
          "isRequired": true,
          "isSecret": false
        },
        {
          "name": "FACILITATOR_URL",
          "description": "x402 facilitator endpoint. Default https://x402.org/facilitator (testnet) or self-hosted.",
          "isRequired": false,
          "isSecret": false,
          "default": "https://x402.org/facilitator"
        },
        {
          "name": "NETWORK",
          "description": "CAIP-2 network identifier. Default solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1 (devnet)",
          "isRequired": false,
          "isSecret": false,
          "default": "solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1"
        },
        {
          "name": "PORT",
          "description": "Listen port",
          "isRequired": false,
          "isSecret": false,
          "default": "4021"
        }
      ]
    }
  ]
}
