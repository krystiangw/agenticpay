{
  "name": "@agenticpay/mcp-server",
  "version": "0.0.1",
  "description": "Pay-per-tool-call HTTP server with x402 USDC paywall on Solana",
  "license": "MIT",
  "homepage": "https://github.com/krystiangw/agenticpay#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krystiangw/agenticpay.git",
    "directory": "packages/mcp-server"
  },
  "keywords": [
    "x402",
    "solana",
    "usdc",
    "mcp",
    "ai-agents",
    "paywall",
    "express",
    "agentic-payments"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agenticpay/sdk": "workspace:*",
    "@x402/core": "^2.11.0",
    "@x402/express": "^2.11.0",
    "@x402/svm": "^2.11.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6"
  }
}
