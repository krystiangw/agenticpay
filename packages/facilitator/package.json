{
  "name": "@agenticpay/facilitator",
  "version": "0.0.1",
  "description": "Self-hosted x402 facilitator: verify + settle USDC payments on Solana",
  "license": "MIT",
  "homepage": "https://github.com/krystiangw/agenticpay#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krystiangw/agenticpay.git",
    "directory": "packages/facilitator"
  },
  "keywords": [
    "x402",
    "facilitator",
    "solana",
    "usdc",
    "ai-agents",
    "payments",
    "express",
    "agentic-payments"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx --env-file=../../.env src/index.ts",
    "start": "node --env-file=../../.env dist/index.js",
    "fund": "tsx --env-file=../../.env src/fund.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agenticpay/sdk": "workspace:*",
    "@solana/kit": "^7.0.0",
    "@solana/web3.js": "^1.95.4",
    "@x402/core": "^2.18.0",
    "@x402/svm": "^2.18.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "posthog-node": "^5.45.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1"
  }
}
