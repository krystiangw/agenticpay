{
  "name": "@agenticpay/sdk",
  "version": "0.0.1",
  "description": "TypeScript SDK for agentpay: Solana + USDC primitives for AI agent micropayments",
  "license": "MIT",
  "homepage": "https://github.com/krystiangw/agentpay#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krystiangw/agentpay.git",
    "directory": "packages/sdk"
  },
  "keywords": [
    "x402",
    "solana",
    "usdc",
    "stablecoin",
    "ai-agents",
    "micropayments",
    "agentic-payments",
    "mcp"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke": "tsx src/smoke.ts"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.4",
    "bs58": "^6.0.0"
  }
}
